---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"journey">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = new Date(entry.data.pubDatetime);
const dateStr = date.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
});
---

<div class="journey-card" data-journey-card>
  <div class="card-aurora" data-card-aurora></div>
  <div class="card-border-glow" data-card-border></div>
  <div class="journey-dot"></div>

  <button class="journey-header" data-journey-toggle aria-expanded="false">
    <div class="journey-date">{dateStr}</div>
    <div class="journey-info">
      <div class="journey-title-row">
        <span class="journey-title">{entry.data.title}</span>
        <span class={`journey-type type-${entry.data.type}`}>
          {entry.data.type}
        </span>
      </div>
      <p class="journey-desc">{entry.data.description}</p>
      {
        entry.data.skills.length > 0 && (
          <div class="journey-skills">
            {entry.data.skills.map(skill => (
              <span class="skill-tag">{skill}</span>
            ))}
          </div>
        )
      }
    </div>
    <svg
      class="chevron"
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M5 7.5L10 12.5L15 7.5"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>

  <div class="journey-content" data-journey-content>
    <div class="journey-content-inner">
      <div class="journey-body">
        <Content />
      </div>
    </div>
  </div>
</div>
